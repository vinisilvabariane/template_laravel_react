{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "target": "ESNext",
        "module": "ESNext",
        "jsx": "react-jsx",
        "moduleResolution": "Node",
        "strict": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,

        "baseUrl": ".",
        "paths": {
            "@": ["resources/ts"],
            "@/*": ["resources/ts/*"]
        },

        "types": ["vite/client"]
    },
    "include": ["resources/ts/**/*.ts", "resources/ts/**/*.tsx"]
}
